# Replace this value with a long random secret in production.
JWT_SECRET=change-me

# Docker PostgreSQL credentials.
POSTGRES_USER=sart
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Optional non-Docker database overrides.
# DEMO_DATABASE_URL=postgresql+psycopg://sart:password@localhost:5432/sart_demo
# WORK_DATABASE_URL=postgresql+psycopg://sart:password@localhost:5432/sart_work

REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=30
WEB_CONCURRENCY=2
SEED_DEMO_DATA=true

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173
