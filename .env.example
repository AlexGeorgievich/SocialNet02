# Replace this value with a long random secret in production.
JWT_SECRET=change-me

# Demo database is committed for a reproducible presentation.
# DEMO_DATABASE_URL=sqlite:///backend/database.demo.db

# Working data is isolated and ignored by Git.
# WORK_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/sart

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173
